# Wippestoolen NAS Deployment - Environment Variables
# Add these in Portainer under Stack → Environment variables

# Database
POSTGRES_PASSWORD=<sicheres-passwort-generieren>

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=<jwt-secret-generieren>

# Cloudflare Tunnel
# Create at: https://one.dash.cloudflare.com → Networks → Tunnels
# Route: api.wippestoolen.de → http://wippestoolen_api:8000
CLOUDFLARE_TUNNEL_TOKEN=<tunnel-token>
